# Smart Crowd AI — Environment Configuration
# ================================================

# ── App Info ───────────────────────────────────
VITE_APP_NAME="Smart Crowd AI"
VITE_APP_ENV=development # development, production, test

# ── Firebase Configuration ──────────────────────
# Get these from: Firebase Console -> Project Settings -> General
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ── API Endpoints ──────────────────────────────
# Base URL for backend services (if applicable)
VITE_API_BASE_URL=https://api.smartcrowd.ai/v1

# ── Feature Flags ──────────────────────────────
# Enable/Disable specific features globally
VITE_ENABLE_SIMULATION=true
VITE_ENABLE_AI_RECOMMENDATIONS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_EXPORT=true

# ── Maintenance Mode ───────────────────────────
# Set to true to show the full-screen maintenance overlay
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_MESSAGE=Smart Crowd AI is temporarily unavailable for scheduled maintenance.
VITE_MAINTENANCE_ESTIMATED_TIME=15 minutes
VITE_MAINTENANCE_CONTACT_EMAIL=support@smartcrowd.ai
VITE_MAINTENANCE_CONTACT_PHONE=

# ── Simulation Engine ──────────────────────────
# Refresh interval in milliseconds
VITE_SIM_REFRESH_INTERVAL=3000
VITE_SIM_AUTO_START=false
